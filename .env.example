# PokerMind 环境变量示例
# 复制为 .env 并填入真实 key。.env 已在 .gitignore 中,绝不入 git。
# 加载方式(任选其一):
#   - shell 启动时 source .env
#   - 用 direnv(在仓库根放 .envrc 写: source .env)
#   - 显式 export(参考 cmd/pokermind 的 run 子命令默认从环境读)

# ===== DeepSeek =====
# 文档: https://api-docs.deepseek.com/
# base_url 不含 /v1(文档明写:https://api.deepseek.com)
POKERMIND_DEEPSEEK_API_KEY=
POKERMIND_DEEPSEEK_BASE_URL=https://api.deepseek.com
# 模型名:deepseek-v4-flash(非思考)/ deepseek-v4-pro(思考)
# 旧名 deepseek-chat / deepseek-reasoner 将于 2026/07/24 弃用,
# 届时分别对应 deepseek-v4-flash 的 non-thinking / thinking 模式。
# 运行时按 --model 选,这里只是参考默认。
POKERMIND_DEEPSEEK_FLASH_MODEL=deepseek-v4-flash
POKERMIND_DEEPSEEK_PRO_MODEL=deepseek-v4-pro

# ===== 智谱 GLM =====
# 文档: https://docs.bigmodel.cn/
POKERMIND_GLM_API_KEY=
POKERMIND_GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
POKERMIND_GLM_MODEL=glm-4.6

# ===== 通用 =====
# 单次 provider 调用超时(秒)
POKERMIND_HTTP_TIMEOUT_SECONDS=60
